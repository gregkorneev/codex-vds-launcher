{
  "name": "codex-cli-launcher",
  "version": "1.0.0-beta.7",
  "description": "Desktop launcher for running Codex CLI locally or on a VDS over SSH",
  "desktopName": "Codex CLI Launcher Beta",
  "displayVersion": "Developer Beta 7 (1.0.0-beta.7)",
  "releaseName": "Codex CLI Launcher Developer Beta 7",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild",
    "postinstall": "electron-builder install-app-deps",
    "dist": "electron-builder --publish never",
    "dist:mac": "electron-builder --mac dmg zip --publish never",
    "dist:win": "electron-builder --win nsis --x64 --publish never -c.npmRebuild=false",
    "publish:beta": "electron-builder --publish always -c.publish.channel=beta -c.publish.releaseType=prerelease",
    "publish:release": "electron-builder --publish always -c.publish.channel=latest -c.publish.releaseType=release -c.productName=\"Codex CLI Launcher\" -c.artifactName=\"Codex-CLI-Launcher-${version}-${os}-${arch}.${ext}\"",
    "check": "node --check src/main.js && node --check src/preload.js && node --check src/renderer/app.js && node --check src/shared/codex-account.js && node --check src/shared/user-projects.js && node --check src/shared/update-policy.js && node --check src/web/project-store.js",
    "test": "node --test",
    "license:summary": "license-checker --summary",
    "license:prod": "license-checker --production"
  },
  "build": {
    "appId": "app.codex-vds.launcher",
    "productName": "Codex CLI Launcher Beta",
    "artifactName": "Codex-CLI-Launcher-Beta-${version}-${os}-${arch}.${ext}",
    "files": [
      "src/**/*",
      "docs/**/*",
      "LICENSE",
      "NOTICE.md",
      "THIRD_PARTY_NOTICES.md",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "icon": "build/icon.icns",
      "identity": "-",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "differentialPackage": false
    },
    "publish": {
      "provider": "github",
      "owner": "gregkorneev",
      "repo": "codex-vds-launcher",
      "channel": "beta",
      "releaseType": "prerelease"
    }
  },
  "keywords": [
    "electron",
    "codex",
    "vds",
    "ssh"
  ],
  "author": "Codex CLI Launcher contributors",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "license-checker": "^25.0.1"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron-updater": "^6.8.9",
    "node-pty": "^1.1.0"
  }
}
